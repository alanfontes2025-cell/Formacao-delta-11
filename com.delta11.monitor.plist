<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.delta11.monitor</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/alfa/projetos/Formacao-delta-11/monitor-delta11.sh</string>
